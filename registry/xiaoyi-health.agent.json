{
  "$schema": "https://agent-protocol.dev/v1.0/manifest.schema.json",
  "id": "com.openclaw.health",
  "name": "Health Assistant",
  "description": "Query health data and provide analysis covering heart rate, sleep, exercise, stress, and nutrition",
  "version": "1.0.0",
  "author": {
    "name": "OpenClaw Team",
    "url": "https://github.com/openclaw"
  },
  "tags": [
    "health",
    "健康",
    "运动",
    "心率",
    "睡眠",
    "fitness"
  ],
  "license": "MIT",
  "capabilities": [
    {
      "id": "query_health_data",
      "name": "查询健康数据",
      "description": "查询心率、睡眠、运动、压力等健康数据",
      "intents": [
        "我的睡眠怎么样",
        "今天心率多少",
        "查看运动数据",
        "健康概览",
        "how was my sleep last night",
        "what's my heart rate",
        "view my exercise data"
      ],
      "input": {
        "type": "object",
        "properties": {}
      },
      "latency": "low",
      "security_level": "low",
      "cost_per_call": 0
    },
    {
      "id": "analyze_health",
      "name": "健康分析",
      "description": "解读健康数据趋势并提供建议",
      "intents": [
        "分析我的健康趋势",
        "这周运动量够吗",
        "健康建议",
        "health analysis",
        "analyze my health trends",
        "weekly health summary",
        "health recommendations"
      ],
      "input": {
        "type": "object",
        "properties": {}
      },
      "latency": "low",
      "security_level": "low",
      "cost_per_call": 0
    }
  ],
  "runtime": {
    "engine": "openclaw",
    "min_version": "1.0.0",
    "type": "skill",
    "engines": [
      "openclaw"
    ]
  },
  "trust": {
    "permissions": [
      "read_health_data"
    ],
    "sandbox_level": "basic",
    "verified_by": []
  },
  "name_zh": "运动健康助手",
  "description_zh": "查询运动健康数据并提供分析解读，覆盖心率、睡眠、运动、压力、营养等"
}