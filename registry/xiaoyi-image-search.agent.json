{
  "$schema": "https://agent-protocol.dev/v1.0/manifest.schema.json",
  "id": "com.openclaw.image-search",
  "name": "Image Search",
  "description": "Search images and download locally, supporting illustrations for documents, PPTs, and reports",
  "version": "1.0.0",
  "author": {
    "name": "OpenClaw Team",
    "url": "https://github.com/openclaw"
  },
  "tags": [
    "image",
    "图片",
    "搜索",
    "素材",
    "配图"
  ],
  "license": "MIT",
  "capabilities": [
    {
      "id": "search_images",
      "name": "搜索图片",
      "description": "根据关键词搜索图片并下载",
      "intents": [
        "找{query}的图片",
        "搜索{subject}图片",
        "找素材",
        "search images of {query}",
        "find images of {query}",
        "search for {subject} pictures",
        "find stock photos of {topic}"
      ],
      "input": {
        "type": "object",
        "properties": {}
      },
      "latency": "low",
      "security_level": "low",
      "cost_per_call": 0
    }
  ],
  "runtime": {
    "engine": "openclaw",
    "min_version": "1.0.0",
    "type": "skill",
    "engines": [
      "openclaw"
    ]
  },
  "trust": {
    "permissions": [
      "network"
    ],
    "sandbox_level": "basic",
    "verified_by": []
  },
  "name_zh": "图片搜索",
  "description_zh": "搜索图片并下载到本地，支持为文档、PPT、报告查找配图素材"
}