{
  "$schema": "https://agent-protocol.dev/v0.1/manifest.schema.json",
  "id": "com.openclaw.weather",
  "name": "天气查询",
  "description": "获取实时天气和天气预报，支持任意城市查询",
  "version": "1.0.0",
  "author": {
    "name": "OpenClaw Team",
    "url": "https://github.com/openclaw"
  },
  "tags": [
    "weather",
    "天气",
    "forecast",
    "天气预报",
    "temperature"
  ],
  "license": "MIT",
  "capabilities": [
    {
      "id": "get_current_weather",
      "name": "当前天气",
      "description": "查询指定城市的实时温度、湿度、风力等天气信息",
      "intents": [
        "现在{城市}的天气怎么样",
        "{城市}今天多少度",
        "{城市}天气"
      ],
      "input": {
        "type": "object",
        "properties": {}
      },
      "latency": "real-time",
      "security_level": "low",
      "cost_per_call": 0
    },
    {
      "id": "get_forecast",
      "name": "天气预报",
      "description": "查询未来多天的天气预报",
      "intents": [
        "未来{天数}天{城市}天气",
        "{城市}这周天气",
        "weekend weather in {city}"
      ],
      "input": {
        "type": "object",
        "properties": {}
      },
      "latency": "real-time",
      "security_level": "low",
      "cost_per_call": 0
    }
  ],
  "runtime": {
    "engine": "openclaw",
    "min_version": "1.0.0",
    "type": "skill",
    "engines": [
      "openclaw"
    ]
  },
  "trust": {
    "permissions": [
      "network"
    ],
    "sandbox_level": "basic",
    "verified_by": []
  }
}