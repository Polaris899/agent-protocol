{
  "$schema": "https://agent-protocol.dev/v0.2/manifest.schema.json",
  "id": "com.openclaw.weather",
  "name": "天气助手",
  "description": "查询实时天气和未来天气预报，支持国内主要城市",
  "description_i18n": {
    "zh-CN": "查询实时天气和未来天气预报",
    "en": "Query real-time weather and forecasts",
    "ja": "リアルタイムの天気予報を検索"
  },
  "version": "1.0.0",
  "author": {
    "name": "OpenClaw Team",
    "url": "https://github.com/openclaw"
  },
  "keywords": ["天气", "weather", "forecast", "温度", "降水"],
  "category": "weather",
  "tags": ["weather", "天气", "forecast", "天气预报", "temperature"],
  "license": "MIT",
  "capabilities": [
    {
      "id": "get_weather",
      "name": "查询当天天气",
      "name_i18n": {
        "zh-CN": "查询当天天气",
        "en": "Get Current Weather",
        "ja": "現在の天気を取得"
      },
      "description": "根据城市名查询当前实时温度、湿度、风速和天气状况",
      "type": "query",
      "mode": "sync",
      "intents": [
        "现在{城市}的天气怎么样",
        "{城市}现在多少度",
        "{城市}今天冷吗",
        "what's the weather in {city} now"
      ],
      "input": {
        "type": "object",
        "properties": {
          "city": { "type": "string", "description": "城市名称，如北京、上海、广州" },
          "unit": { "type": "string", "enum": ["celsius", "fahrenheit"], "default": "celsius" }
        },
        "required": ["city"]
      },
      "output": {
        "type": "object",
        "description": "天气数据，包含温度、湿度、风速、天气状况",
        "example": {
          "city": "北京",
          "temperature": 22,
          "humidity": 65,
          "wind_speed": 12,
          "condition": "晴"
        }
      },
      "latency": "real-time",
      "security_level": "low",
      "cost_per_call": 0,
      "timeout_ms": 10000,
      "rate_limit": {
        "max_per_minute": 60,
        "max_per_day": 10000
      }
    },
    {
      "id": "get_forecast",
      "name": "天气预报",
      "name_i18n": {
        "zh-CN": "天气预报",
        "en": "Weather Forecast",
        "ja": "天気予報"
      },
      "description": "查询指定城市未来几天的天气预报，包括最高最低温度、降水概率等",
      "type": "query",
      "mode": "sync",
      "intents": [
        "未来{天数}天{城市}的天气",
        "{城市}这周天气",
        "{城市}周末天气",
        "forecast for {city} for {days} days"
      ],
      "input": {
        "type": "object",
        "properties": {
          "city": { "type": "string", "description": "城市名称" },
          "days": { "type": "integer", "description": "预报天数", "default": 3, "minimum": 1, "maximum": 15 }
        },
        "required": ["city"]
      },
      "output": {
        "type": "array",
        "description": "每日预报数据列表"
      },
      "latency": "real-time",
      "security_level": "low",
      "cost_per_call": 0,
      "timeout_ms": 10000
    }
  ],
  "runtime": {
    "engine": "openclaw",
    "min_version": "1.0.0",
    "engines": ["openclaw"],
    "type": "skill",
    "entrypoint": "main.py",
    "requirements": {
      "system": {
        "memory_mb": 128,
        "disk_mb": 10,
        "network": true,
        "bins": ["curl"]
      }
    }
  },
  "trust": {
    "permissions": ["network"],
    "sandbox_level": "basic"
  }
}
